```gitignore
# Virtual Environment
venv/
.venv/
env/
ENV/

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / Packaging
build/
dist/
*.egg-info/
.eggs/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit Test / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Playwright
playwright-report/
test-results/
blob-report/

# IDEs
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# Environment Variables
.env
.env.*

# Logs
*.log

# Jupyter Notebook
.ipynb_checkpoints/

# mypy
.mypy_cache/

# Ruff
.ruff_cache/

# PyCharm
*.iml

# Temporary files
*.tmp
*.temp

# SQLite
*.sqlite3

# Local configuration
.python-version
```
